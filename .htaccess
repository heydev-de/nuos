Options -Multiviews

<IfModule mod_dir.c>
DirectoryIndex index.php
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine on
RewriteBase /

# redirect to canonical domain
#RewriteCond %{SERVER_PORT} !^443$ [OR]
#RewriteCond %{HTTP_HOST} !^example\.com$
#RewriteRule ^ https://example.com%{REQUEST_URI} [NE,L,R=301]

# secure dat files
RewriteCond %{REQUEST_FILENAME} \.dat$
RewriteRule ^ /404.php [L,R=404]

# evoke 404 on missing php scripts
RewriteCond %{REQUEST_FILENAME} \.php$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /404.php [L,R=404]

# connect /sitemap.xml
RewriteCond %{REQUEST_URI} ^/sitemap\.xml$ [NC]
RewriteRule ^ /nuos/module/sitemap.php [L]

# connect /rss.xml
RewriteCond %{REQUEST_URI} ^/rss\.xml$
RewriteRule ^ /nuos/module/rss.php?rss_channel=6ZQKdNzP&rss_order=modified [L]
</IfModule>

ErrorDocument 404 /404.php

<IfModule mod_deflate.c>
#AddOutputFilterByType DEFLATE application/rss+xml
AddOutputFilterByType DEFLATE application/xml
AddOutputFilterByType DEFLATE image/svg+xml
AddOutputFilterByType DEFLATE text/css
#AddOutputFilterByType DEFLATE text/html
AddOutputFilterByType DEFLATE text/javascript
</IfModule>